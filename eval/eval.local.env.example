# Local eval settings — copy to `eval.local.env` (gitignored) and fill in for your machine.
# `npm run eval` / `npm run semantic-probe` load this automatically. Anything you set in your
# shell still wins over these values.

# LM Studio API token (Developer tab → server settings). Required if the server enforces auth.
EVAL_API_KEY=sk-lm-xxxxxxxx:xxxxxxxxxxxxxxxxxxxx

# Chat model under test. Omit to auto-pick the first model the server advertises.
# EVAL_MODEL=google/gemma-4-12b-qat

# Embedding model for the semantic router (must be loaded in LM Studio).
EVAL_EMBED_MODEL=text-embedding-nomic-embed-text-v2-moe

# Judge model — a STRONGER model than the one under test gives far fewer unparseable verdicts.
EVAL_JUDGE_MODEL=qwen3.6-27b-mtp

# Majority-vote the judge (1 = single call). Bump to 3 to harden a weak/borderline judge.
EVAL_JUDGE_VOTES=1
